# reference clone (analysis only — never packaged)
ref-pr-monitor/
wf-findings/

# python
.venv/
__pycache__/
*.pyc

# secrets (never commit — go to userConfig/keychain)
config/delivery.yaml
.env
.env.local
*.key

# workspace runtime state (created at runtime under PROJECT_DIR / PLUGIN_DATA)
data/raw/
data/processed/
data/cache/
data/output/
logs/
.prmonitor-initialized

# domain-pack live config: real packs (generated by /setup) stay untracked,
# but bundled examples are tracked — config-templates/ and config/examples/.
config/*.yaml
!config-templates/**
!config/examples/
!config/examples/**

# private domain packs (real org data — never committed)
domain-packs/

# OMC orchestration / session state (local only)
.omc/
.claude/

# runtime self-context (operator-populated; only *.sample.* are tracked templates)
data/self-context/*
!data/self-context/*.sample.*
